# ─── Site ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Price snapshot (used by `npm run prices:build` and GitHub Actions) ─
# See .github/workflows/refresh-prices.yml. Keys are not needed at runtime
# for read-only /api/prices; add them as repository secrets: GOLD_API_KEY,
# EXCHANGE_RATE_API_KEY. Local: npm run prices:build. Dev without keys:
# npm run prices:seed
GOLD_API_KEY=your_goldapi_key_here
EXCHANGE_RATE_API_KEY=your_exchangerate_key_here

# Default currency when /api/prices is called with no ?currency= query
DEFAULT_CURRENCY=EGP
